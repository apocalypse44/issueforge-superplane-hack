# LLM provider: groq | ollama
LLM_PROVIDER=ollama

# Groq (cloud, fast — free tier has rate limits)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (local, free, open source — https://ollama.com)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Required for --full (push branch + create PR)
GITHUB_TOKEN=ghp_...
OUTPUT_REPO=apocalypse44/issueforge-superplane-hack

# Optional: Render preview after --full
RENDER_API_KEY=rnd_...
RENDER_SERVICE_ID=srv-...
